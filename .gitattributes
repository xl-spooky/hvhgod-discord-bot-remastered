# Normalize line endings for text files to LF on all platforms
*.py      text eol=lf
*.toml    text eol=lf
*.ini     text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.sh      text eol=lf
*.env     text eol=lf
.env      text eol=lf
.env.*    text eol=lf
docker.env text eol=lf
.env.example text eol=lf

# Windows scripts may prefer CRLF
*.ps1     text eol=crlf
*.bat     text eol=crlf

# Binary files (do not modify line endings)
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.pdf     binary

# shellcheck disable=2148,2034
# vi: ft=bash
# it's a .env file, calm down shellcheck

# Base configuration (fill out the empty values)

# Discord application credentials
SPOOKY_BOT__TOKEN=
SPOOKY_BOT__SECRET=
SPOOKY_BOT__CLIENT_ID=

# Runtime and logging
SPOOKY_BOT__ENV=DEV       # one of: DEV, PROD
SPOOKY_LOG__LEVEL=INFO    # DEBUG, INFO, WARNING, ERROR
PYTHONDONTWRITEBYTECODE=1 # prevent __pycache__/.pyc creation locally
SPOOKY_TELEMETRY_CHANNEL_ID=   # optional: numeric channel ID for error telemetry

# Database (PostgreSQL)
#
# You can either provide a full DATABASE_URL or rely on the granular values below.
# When running everything in docker-compose, DB_HOST should normally stay as "db".

DATABASE_URL=postgresql+asyncpg://spooky:spooky@db:5432/spookydb
DB_DRIVER=postgresql+asyncpg
DB_HOST=db
DB_PORT=5432
DB_USER=spooky
DB_PASS=spooky
DB_NAME=spookydb
DB_ECHO=0              # set to 1 to echo SQL
DB_POOL_SIZE=          # optional: integer pool size override
DB_MAX_OVERFLOW=       # optional: integer overflow connections
DB_POOL_TIMEOUT=       # optional: seconds before giving up acquiring a connection
DB_POOL_RECYCLE=       # optional: seconds before recycling a connection

# Redis Cache
# Provide either REDIS_URL or granular parts below (defaults match docker compose)
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_USER=
REDIS_PASS=
REDIS_SSL=0

# Note: legacy keys removed (Top.gg, Steam/Google APIs, telemetry). Add back
# only when corresponding features are implemented.
